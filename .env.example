# ─────────────────────────────────────────────
# Network Visualization Platform — Environment Reference
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# ── Startup Mode ────────────────────────────
# serve              Start the web server only (default)
# ingest             Run data ingestion and exit (no server started)
# ingest-and-serve   Ingest data first, then start the web server
#
# In Docker, set START_MODE=ingest-and-serve on first run,
# then switch to START_MODE=serve once the DB is populated.
# Or leave it as 'serve' — the server auto-ingests on first run
# if the database is empty.
START_MODE=serve

# CORS (restrict in production, e.g. https://your-domain.com)
CORS_ORIGIN=*

# ── Database ────────────────────────────────
# Path to the SQLite database file.
# In Docker: point to your mounted volume, e.g. /data/network_viz.db
DB_PATH=./data/network_viz.db

# ── Data File Locations ─────────────────────
# Place your data files in the directories below (or override these paths).
#
#   Network CSVs:       data/networks/*.csv
#     Format: node1,node2,weight  (one edge per line, no header)
#     Example: ProteinA,ProteinB,0.95
#
#   Node attributes:    data/nodes_attr/*.nodes.attr
#     Exactly one .nodes.attr file is required.
#     Format: comma-separated with a header row — node_id, NCBI_txID, NH_ID, NH_Size, ...
#
#   Species mapping:    data/NCBI_txID/
#     NCBI taxonomy CSV files used by the species-names API
#
# In Docker: mount your data volume to /app/data and set paths below.
DATA_PATH=./data/networks
INDEXES_PATH=./data/indexes
TEMP_DATA_PATH=./data/tmp
NODE_ATTRIBUTES_PATH=./data/nodes_attr
SPECIES_PATH=./data/NCBI_txID/NCBI_txID.csv

# ── File Watching ────────────────────────────
# Set to false to disable hot-reload of data files.
# Recommended: false for static/production containers,
#              true for development or live-data mounts.
FILE_WATCH_ENABLED=true

# ── Subnetwork Extraction ───────────────────
# Python command used by POST /api/subnetworks
PYTHON_COMMAND=python3

# Script path and temp job directory
SUBNETWORK_SCRIPT_PATH=./tools/runtime/extract_subnetwork.py
SUBNETWORK_JOB_TEMP_PATH=./data/tmp/subnetwork-jobs

# Request limits
SUBNETWORK_MAX_SEEDS=10
SUBNETWORK_MAX_INPUT_LENGTH=2000
SUBNETWORK_MAX_NAME_LENGTH=80
SUBNETWORK_DEFAULT_MAX_NODES=500
SUBNETWORK_MAX_NODES_LIMIT=2000
SUBNETWORK_TIMEOUT_MS=120000
SUBNETWORK_MAX_CONCURRENT_JOBS=2

# ── Edited Network Saves ──────────────────────
# Limits for saving a manually edited network from the viewer.
NETWORK_EDIT_MAX_NAME_LENGTH=80
NETWORK_EDIT_MAX_SUFFIX_ATTEMPTS=1000

# Internal file-watcher dedupe for edited networks written by the app itself.
# The watcher skips this many add/change events for the saved filename, expiring
# stale suppressions after the max age below.
NETWORK_EDIT_WATCHER_SUPPRESS_EVENTS=3
NETWORK_EDIT_WATCHER_SUPPRESS_MS=300000

# ── Memory ───────────────────────────────────
# Set this BEFORE starting Node — it must be in the environment at launch,
# not inside the process. In Docker use ENV or in npm scripts use:
#   NODE_OPTIONS=--max-old-space-size=4096 node backend/entrypoint.js
# NODE_OPTIONS=--max-old-space-size=4096

# ── Logging ──────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/server.log
